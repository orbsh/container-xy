:8080 {
    root "/srv"
    cgi
    cgi_extension ".nu"

    rewrite "^/bin(.*)" "/ferron/bin.nu$1" file=#true directory=#true last=#true
    rewrite "^/box(.*)" "/ferron/box.nu$1" file=#true directory=#true last=#true
    rewrite "^/vessel(.*)" "/ferron/vessel.nu$1" file=#true directory=#true last=#true

    rewrite "^/(.*)" "/ferron/index.nu/$1" file=#true directory=#true last=#true

    // location "/box" remove_base=#true {
    // }

    log "/dev/stdout"
    error_log "/dev/stderr"
}
